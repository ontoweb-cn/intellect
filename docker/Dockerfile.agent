# =============================================================================
# Dockerfile.agent — Intellect Agent container image (binaries + runtime data)
# =============================================================================
# Runtime image contains NO Python source tree. Only:
#   /opt/intellect/bin/intellect*  — Nuitka onefile binaries
#   /opt/intellect/skills/         — bundled skill data
#   /opt/intellect/locales/        — i18n data
#   /opt/intellect/assets/         — static assets
#   /opt/intellect/docker/         — bootstrap files (SOUL.md, entrypoint)
#   /opt/intellect/.playwright/    — browser bundle for Playwright skills
#
# Build:
#   docker build -f docker/Dockerfile.agent -t ontoweb/intellect-agent:latest ../intellect-agent
#   (build-docker.sh passes --build-context intellect-orchestrator for the entrypoint)
# =============================================================================

FROM ghcr.io/astral-sh/uv:0.11.6-python3.13-trixie@sha256:b3c543b6c4f23a5f2df22866bd7857e5d304b67a564f4feab6ac22044dde719b AS uv_source
FROM tianon/gosu:1.19-trixie@sha256:3b176695959c71e123eb390d427efc665eeb561b1540e82679c15e992006b8b9 AS gosu_source

# ---------- Stage: full build environment (discarded except artifacts) ----------
FROM debian:13.4 AS builder

ENV PYTHONUNBUFFERED=1
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/intellect/.playwright

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    build-essential curl nodejs npm python3 ripgrep ffmpeg gcc g++ python3-dev \
    libffi-dev procps git openssh-client docker-cli patchelf ccache && \
    rm -rf /var/lib/apt/lists/*

COPY --chmod=0755 --from=uv_source /usr/local/bin/uv /usr/local/bin/uvx /usr/local/bin/

WORKDIR /opt/intellect

COPY package.json package-lock.json ./
COPY ui-tui/package.json ui-tui/package-lock.json ui-tui/
COPY ui-tui/packages/intellect-ink/ ui-tui/packages/intellect-ink/

ENV npm_config_install_links=false
RUN npm install --no-audit \
    && npx playwright install --with-deps chromium --only-shell \
    && cd ui-tui && npm install --no-audit \
    && npm cache clean --force

COPY pyproject.toml uv.lock ./
RUN touch ./README.md \
    && uv sync --frozen --no-install-project --extra all

COPY . .

RUN cd ui-tui && npm run build

# ---------- Stage: compile Nuitka binaries ----------
FROM builder AS binary_builder

RUN uv pip install --no-cache-dir 'nuitka==2.8.10' cython ordered-set

RUN mkdir -p /out /tmp/launch \
    && printf 'import sys\nfrom intellect_cli.main import main\nsys.exit(main() or 0)\n' > /tmp/launch/intellect.py \
    && printf 'import sys\nfrom run_agent import main\nsys.exit(main() or 0)\n' > /tmp/launch/intellect-agent.py \
    && printf 'import sys\nfrom acp_adapter.entry import main\nsys.exit(main() or 0)\n' > /tmp/launch/intellect-acp.py

ENV PYTHONPATH=/opt/intellect
RUN cd /opt/intellect && \
    uv run python -m nuitka \
      --onefile \
      --output-dir=/out \
      --output-filename=intellect \
      --lto=yes \
      --jobs="$(nproc)" \
      --python-flag=-OO \
      --noinclude-setuptools-mode=nofollow \
      --enable-plugin=anti-bloat \
      --assume-yes-for-downloads \
      --include-module=unittest.mock \
      --include-data-dir=skills=skills \
      --include-data-dir=optional-skills=optional-skills \
      --include-data-dir=locales=locales \
      --include-data-dir=assets=assets \
      --include-package-data=gateway \
      /tmp/launch/intellect.py && \
    uv run python -m nuitka \
      --onefile \
      --output-dir=/out \
      --output-filename=intellect-agent \
      --lto=yes \
      --jobs="$(nproc)" \
      --python-flag=-OO \
      --noinclude-setuptools-mode=nofollow \
      --enable-plugin=anti-bloat \
      --assume-yes-for-downloads \
      --include-module=run_agent \
      --include-data-dir=skills=skills \
      --include-data-dir=optional-skills=optional-skills \
      --include-data-dir=locales=locales \
      /tmp/launch/intellect-agent.py && \
    uv run python -m nuitka \
      --onefile \
      --output-dir=/out \
      --output-filename=intellect-acp \
      --lto=yes \
      --jobs="$(nproc)" \
      --python-flag=-OO \
      --noinclude-setuptools-mode=nofollow \
      --enable-plugin=anti-bloat \
      --assume-yes-for-downloads \
      --include-package=acp_adapter \
      /tmp/launch/intellect-acp.py

RUN test -x /out/intellect && test -x /out/intellect-agent && test -x /out/intellect-acp

# ---------- Stage: minimal runtime ----------
FROM debian:13.4 AS runtime

ENV PYTHONUNBUFFERED=1
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/intellect/.playwright
ENV INTELLECT_HOME=/opt/data
ENV INTELLECT_BUNDLED_SKILLS=/opt/intellect/skills
ENV PATH="/opt/intellect/bin:/opt/data/.local/bin:${PATH}"

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    curl nodejs ripgrep ffmpeg procps git openssh-client docker-cli tini \
    libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
    libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libgbm1 \
    libpango-1.0-0 libcairo2 libasound2 \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -u 10000 -m -d /opt/data intellect

COPY --chmod=0755 --from=gosu_source /gosu /usr/local/bin/
COPY --from=binary_builder /out/intellect /out/intellect-agent /out/intellect-acp /opt/intellect/bin/
COPY --from=builder /opt/intellect/skills /opt/intellect/skills
COPY --from=builder /opt/intellect/optional-skills /opt/intellect/optional-skills
COPY --from=builder /opt/intellect/locales /opt/intellect/locales
COPY --from=builder /opt/intellect/assets /opt/intellect/assets
COPY --from=builder /opt/intellect/.playwright /opt/intellect/.playwright
COPY --from=builder /opt/intellect/docker/SOUL.md /opt/intellect/docker/SOUL.md
COPY --from=builder /opt/intellect/.env.example /opt/intellect/.env.example
COPY --from=builder /opt/intellect/cli-config.yaml.example /opt/intellect/cli-config.yaml.example
COPY --from=intellect-orchestrator --chmod=0755 docker/agent-entrypoint.bash /opt/intellect/docker/entrypoint.sh

RUN chmod -R a+rX /opt/intellect \
    && chown -R intellect:intellect /opt/intellect/.playwright 2>/dev/null || true

VOLUME [ "/opt/data" ]
ENTRYPOINT [ "/usr/bin/tini", "-g", "--", "/opt/intellect/docker/entrypoint.sh" ]
